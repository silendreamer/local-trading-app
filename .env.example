# Keep real secrets in .env, which is ignored by git.
APP_ENV=local
LOG_LEVEL=INFO
PAPER_STARTING_CASH=100000
DRY_RUN=true
ALPACA_PAPER=true
AUTO_TRADE=false
POLYGON_API_KEY=
SNAPSHOT_STORAGE=github
GITHUB_SNAPSHOT_REPO=your-github-user-or-org/local-trading-app
GITHUB_SNAPSHOT_BRANCH=snapshot-data
GITHUB_SNAPSHOT_DIR=snapshots
GITHUB_SNAPSHOT_TOKEN=

# Alpaca paper-trading credentials only.
# Never put live-trading credentials in this project.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
