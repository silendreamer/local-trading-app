# Keep real secrets in .env, which is ignored by git.
APP_ENV=local
LOG_LEVEL=INFO
PAPER_STARTING_CASH=100000
DRY_RUN=true
ALPACA_PAPER=true
AUTO_TRADE=false
POLYGON_API_KEY=

# Alpaca paper-trading credentials only.
# Never put live-trading credentials in this project.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
